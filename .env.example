# Root workspace example variables
# Copy relevant values into apps/api/.env and apps/web/.env.production before deployment.

NODE_ENV=production
APP_DOMAIN=commune.example.ci
API_DOMAIN=api.commune.example.ci

# Frontend public API base URL
NEXT_PUBLIC_API_BASE_URL=https://api.commune.example.ci

# Backend
PORT=3005
JWT_SECRET=change-this-super-secret-production-key
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/civitech_commune
