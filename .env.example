# ==========================================
# CiviTech Commune SaaS - Configuration
# ==========================================
# Copy ce fichier en .env et remplissez les valeurs appropriées

# ==========================================
# Environnement
# ==========================================
NODE_ENV=production
APP_DOMAIN=commune.example.ci
API_DOMAIN=api.commune.example.ci

# ==========================================
# Base de Données
# ==========================================
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/civitech_commune

# ==========================================
# API Backend
# ==========================================
PORT=3005
API_URL=https://api.commune.example.ci
NODE_ENV=production

# ==========================================
# Frontend
# ==========================================
NEXT_PUBLIC_API_BASE_URL=https://api.commune.example.ci
NEXT_PUBLIC_APP_NAME=CiviTech Commune
NEXT_PUBLIC_MUNICIPALITY=Niakara

# ==========================================
# Authentification
# ==========================================
JWT_SECRET=change-this-super-secret-production-key
JWT_EXPIRY=7d

# ==========================================
# Email (optionnel)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@civitech.com

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=https://commune.example.ci,https://api.commune.example.ci

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
